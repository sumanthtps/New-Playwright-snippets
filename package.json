{
  "name": "playwright-test-code-snippets",
  "displayName": "Playwright Studio",
  "license": "MIT",
  "author": "Sumanth T P",
  "publisher": "sumanthtps",
  "description": "338 Playwright snippets plus Run, Debug, Inspect, Codegen, Trace Viewer, and HTML Report inside VS Code",
  "homepage": "https://github.com/sumanthtps/New-Playwright-snippets",
  "repository": {
    "type": "git",
    "url": "https://github.com/sumanthtps/New-Playwright-snippets.git"
  },
  "bugs": "https://github.com/sumanthtps/New-Playwright-snippets/issues",
  "icon": "images/playwright-logo.png",
  "galleryBanner": {
    "color": "#0f6b44",
    "theme": "dark"
  },
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Snippets",
    "Testing"
  ],
  "keywords": [
    "playwright",
    "playwright-test",
    "playwright snippets",
    "playwright studio",
    "e2e",
    "end-to-end",
    "testing",
    "automation",
    "test automation",
    "codelens",
    "test runner",
    "trace viewer",
    "codegen",
    "html report",
    "typescript",
    "javascript"
  ],
  "markdown": "github",
  "qna": "marketplace",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "contributes": {
    "snippets": [
      {
        "language": "javascript",
        "path": "./snippets/playwright.json"
      },
      {
        "language": "javascriptreact",
        "path": "./snippets/playwright.json"
      },
      {
        "language": "typescript",
        "path": "./snippets/playwright.json"
      },
      {
        "language": "typescriptreact",
        "path": "./snippets/playwright.json"
      }
    ],
    "commands": [
      {
        "command": "playwrightSnippets.runTest",
        "title": "Playwright Studio: Run Test"
      },
      {
        "command": "playwrightSnippets.runFile",
        "title": "Playwright Studio: Run All Tests in File"
      },
      {
        "command": "playwrightSnippets.debugTest",
        "title": "Playwright Studio: Debug Test"
      },
      {
        "command": "playwrightSnippets.debugFile",
        "title": "Playwright Studio: Debug All Tests in File"
      },
      {
        "command": "playwrightSnippets.inspectTest",
        "title": "Playwright Studio: Inspect Test (PWDEBUG=1)"
      },
      {
        "command": "playwrightSnippets.inspectFile",
        "title": "Playwright Studio: Inspect All Tests in File"
      },
      {
        "command": "playwrightSnippets.debugInspectTest",
        "title": "Playwright Studio: Debug Test with Inspector"
      },
      {
        "command": "playwrightSnippets.debugInspectFile",
        "title": "Playwright Studio: Debug All Tests with Inspector"
      },
      {
        "command": "playwrightSnippets.runTestAtCursor",
        "title": "Playwright Studio: Run Test at Cursor"
      },
      {
        "command": "playwrightSnippets.codeGen",
        "title": "Playwright Studio: Open Codegen"
      },
      {
        "command": "playwrightSnippets.showTrace",
        "title": "Playwright Studio: Show Trace Viewer"
      },
      {
        "command": "playwrightSnippets.showReport",
        "title": "Playwright Studio: Show HTML Report"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "playwrightSnippets.runTestAtCursor",
          "when": "editorTextFocus && resourceExtname =~ /\\.[jt]sx?$/",
          "group": "playwright@1"
        },
        {
          "command": "playwrightSnippets.codeGen",
          "when": "editorTextFocus",
          "group": "playwright@2"
        }
      ],
      "editor/title": [
        {
          "command": "playwrightSnippets.runFile",
          "when": "resourceExtname =~ /\\.[jt]sx?$/",
          "group": "navigation@1"
        },
        {
          "command": "playwrightSnippets.debugFile",
          "when": "resourceExtname =~ /\\.[jt]sx?$/",
          "group": "navigation@2"
        },
        {
          "command": "playwrightSnippets.debugInspectFile",
          "when": "resourceExtname =~ /\\.[jt]sx?$/",
          "group": "navigation@3"
        }
      ],
      "explorer/context": [
        {
          "command": "playwrightSnippets.runFile",
          "when": "resourceExtname =~ /\\.[jt]sx?$/",
          "group": "playwright@1"
        },
        {
          "command": "playwrightSnippets.debugFile",
          "when": "resourceExtname =~ /\\.[jt]sx?$/",
          "group": "playwright@2"
        },
        {
          "command": "playwrightSnippets.debugInspectFile",
          "when": "resourceExtname =~ /\\.[jt]sx?$/",
          "group": "playwright@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "playwrightSnippets.runTestAtCursor",
        "key": "ctrl+shift+p ctrl+shift+r",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Playwright Snippets",
      "properties": {
        "playwrightSnippets.workingDirectory": {
          "type": "string",
          "default": "",
          "description": "Working directory for running Playwright tests (relative to workspace root, or absolute). Defaults to workspace root."
        },
        "playwrightSnippets.testCommand": {
          "type": "string",
          "default": "npx playwright test",
          "description": "Base command used to run Playwright tests."
        },
        "playwrightSnippets.reporter": {
          "type": "string",
          "default": "",
          "description": "Playwright reporter to use (e.g. list, dot, html). Leave empty to use playwright.config.ts default."
        },
        "playwrightSnippets.env": {
          "type": "object",
          "default": {},
          "description": "Additional environment variables to set when running tests.",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "walkthroughs": [
      {
        "id": "playwrightStudio.getStarted",
        "title": "Get started with Playwright Studio",
        "description": "Run Playwright tests, generate code, and inspect failures without leaving VS Code.",
        "steps": [
          {
            "id": "playwrightStudio.runTest",
            "title": "Run a test from the editor",
            "description": "Open a Playwright test file and use CodeLens, the editor tab menu, or the Command Palette to run a test quickly.",
            "media": {
              "image": "images/walkthrough-run.svg",
              "altText": "Playwright Studio run test walkthrough"
            },
            "completionEvents": [
              "onCommand:playwrightSnippets.runTest",
              "onCommand:playwrightSnippets.runFile",
              "onCommand:playwrightSnippets.runTestAtCursor"
            ]
          },
          {
            "id": "playwrightStudio.codegen",
            "title": "Generate Playwright code",
            "description": "Launch Codegen directly from VS Code to record actions and bootstrap new tests faster.",
            "media": {
              "image": "images/walkthrough-codegen.svg",
              "altText": "Playwright Studio codegen walkthrough"
            },
            "completionEvents": [
              "onCommand:playwrightSnippets.codeGen"
            ]
          },
          {
            "id": "playwrightStudio.trace",
            "title": "Open traces and reports",
            "description": "Inspect failures with Trace Viewer or open the Playwright HTML report without leaving the editor.",
            "media": {
              "image": "images/walkthrough-trace.svg",
              "altText": "Playwright Studio trace viewer walkthrough"
            },
            "completionEvents": [
              "onCommand:playwrightSnippets.showTrace",
              "onCommand:playwrightSnippets.showReport"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "compile:prod": "node esbuild.js --production",
    "test": "node --test test/snippets.test.js",
    "package": "npm run compile:prod && vsce package",
    "build": "npm run package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "semantic-release": "^25.0.3",
    "semantic-release-vsce": "^6.1.0",
    "typescript": "^5.7.0"
  }
}
